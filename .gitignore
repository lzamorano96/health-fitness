# ─────────────────────────────────────────────────────────────────────────────
# health-fitness — .gitignore
# Analytical & Precise: each section is explicit and commented.
# ─────────────────────────────────────────────────────────────────────────────

# ── Python runtime artifacts ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
*.egg-info/
dist/
build/

# ── Testing and coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover
.tox/

# ── Generated exports (always regenerate from source) ────────────────────────
# Grocery lists exported via export_grocery_list.py
grocery*.txt
grocery*.csv
exports/

# Reports exported via fitness-dashboard skill
data/reports/

# Temporary plugin packages (built during packaging, not source)
*.plugin

# ── IDE and editor artifacts ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Operating system artifacts ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.log
.write_*.tmp

# ── Secrets and credentials (belt-and-suspenders) ────────────────────────────
# This project has no secrets, but guard against accidental additions.
.env
.env.*
*.pem
*.key
*.crt
secrets/
credentials/

# ── Data files — explicit inclusions override default exclusions ──────────────
# data/ is fully tracked. No exclusions here.
# If data files ever grow large (>1MB each), migrate to Git LFS:
#   git lfs track "data/logs/*.json"

# ── Node / package managers (future-proofing) ────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json
